# hibi Environment Variables
# Copy this file to .env and fill in the values

# ============================================
# Database (MySQL)
# ============================================
DB_PASSWORD=hibi_dev_password
MYSQL_ROOT_PASSWORD=root_password

# ============================================
# JWT
# ============================================
JWT_SECRET=dev-jwt-secret-key-minimum-32-characters-long

# ============================================
# OAuth (Social Login) - Stage 1에서 설정
# ============================================
# KAKAO_CLIENT_ID=
# KAKAO_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=

# ============================================
# Email (AWS SES or SendGrid) - Stage 1에서 설정
# ============================================
# SES_ACCESS_KEY=
# SES_SECRET_KEY=
# SES_REGION=ap-northeast-2
